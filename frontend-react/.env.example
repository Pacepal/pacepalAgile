# API PHP real servida por Apache/XAMPP.
# En Vite dev/preview esta variable tiene prioridad absoluta.
VITE_PACEPAL_API_BASE_URL=http://localhost/NOMBRE_CARPETA_PROYECTO/src/api/index.php/api

# Ejemplo para la ruta local actual de Pablo:
# VITE_PACEPAL_API_BASE_URL=http://localhost/treecore%20Trabajos/pacepal/src/api/index.php/api

# Fallback opcional y explicito solo para entornos sin API PHP real.
VITE_PACEPAL_ENABLE_STATIC_FALLBACK=false
